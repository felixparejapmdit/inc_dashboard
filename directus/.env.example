# Optional Directus values for local development.
# Put these values in the root .env if you want docker compose to read them.

DIRECTUS_KEY=replace-with-a-long-random-key
DIRECTUS_SECRET=replace-with-a-long-random-secret
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-this-password
DIRECTUS_PUBLIC_URL=http://localhost:8055

# Frontend values. Put these in the root .env used by React.
REACT_APP_DIRECTUS_URL=http://localhost:8055
REACT_APP_DIRECTUS_TOKEN=
